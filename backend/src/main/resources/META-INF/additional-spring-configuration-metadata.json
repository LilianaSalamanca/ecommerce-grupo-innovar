{
  "properties": [
    {
      "name": "app.jwt.secret",
      "type": "java.lang.String",
      "description": "JWT secret key used to sign tokens (put a long random value in production)."
    },
    {
      "name": "app.jwt.expiration-ms",
      "type": "java.lang.Long",
      "description": "JWT expiration in milliseconds (default 86400000 = 24h)."
    },
    {
      "name": "app.frontend.url",
      "type": "java.lang.String",
      "description": "Allowed frontend URL for CORS"
    }
  ]
}
